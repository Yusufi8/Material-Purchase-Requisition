<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Quick wizard: opens as a popup dialog -->
    <record id="action_material_requisition_wizard" model="ir.actions.act_window">
        <field name="name">Request Materials</field>
        <field name="res_model">mr.request.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- All material requisitions (Inventory Manager full register) -->
    <record id="action_material_requisition_all" model="ir.actions.act_window">
        <field name="name">Material Requisitions</field>
        <field name="res_model">material.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>

    <!-- My own requisitions (Production Supervisor) -->
    <record id="action_material_requisition_mine" model="ir.actions.act_window">
        <field name="name">My Requisitions</field>
        <field name="res_model">material.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('requested_by', '=', uid)]</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <!-- Requisitions awaiting Inventory action -->
    <record id="action_material_requisition_pending_review" model="ir.actions.act_window">
        <field name="name">Pending Review</field>
        <field name="res_model">material.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', 'in', ['submitted', 'supervisor_approved', 'inventory_review', 'partially_available'])]</field>
    </record>

    <!-- Requisitions awaiting a Director decision -->
    <record id="action_material_requisition_director_queue" model="ir.actions.act_window">
        <field name="name">Director Approval Queue</field>
        <field name="res_model">material.requisition</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'director_approval_required')]</field>
    </record>

    <!-- Manual line-by-line availability review, opened from the MR form -->
    <record id="action_mr_inventory_review_wizard" model="ir.actions.act_window">
        <field name="name">Review &amp; Approve Quantities</field>
        <field name="res_model">ti.inventory.review.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ti_inventory_review_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_mr_id': active_id}</field>
    </record>

    <!-- Opens the shared ti_workflow_core approval wizard pre-set to Approve,
         targeted at the current material.requisition record -->
    <record id="action_mr_director_approve_wizard" model="ir.actions.act_window">
        <field name="name">Director Approve</field>
        <field name="res_model">ti.approval.action.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="ti_workflow_core.view_ti_approval_action_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_res_model': 'material.requisition', 'default_res_id': active_id, 'default_action_type': 'approve'}</field>
    </record>

    <!-- Same wizard, pre-set to Reject -->
    <record id="action_mr_director_reject_wizard" model="ir.actions.act_window">
        <field name="name">Director Reject</field>
        <field name="res_model">ti.approval.action.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="ti_workflow_core.view_ti_approval_action_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_res_model': 'material.requisition', 'default_res_id': active_id, 'default_action_type': 'reject'}</field>
    </record>

</odoo>
