<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Production User: sees only their own requests.
         Production Supervisor: sees their own requests + everything
         raised in a department they manage.
         No rule is defined for Inventory/Purchase/Director/Admin groups —
         absence of a rule means unrestricted visibility for those groups,
         which matches the intended security model (they need to see
         every requisition to do their jobs).
    ============================================================ -->

    <record id="rule_mr_production_user" model="ir.rule">
        <field name="name">Material Requisition: Production User sees own only</field>
        <field name="model_id" ref="model_material_requisition"/>
        <field name="domain_force">[('requested_by', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('ti_workflow_core.group_production_user'))]"/>
    </record>

    <record id="rule_mr_production_supervisor" model="ir.rule">
        <field name="name">Material Requisition: Production Supervisor sees own + managed department</field>
        <field name="model_id" ref="model_material_requisition"/>
        <field name="domain_force">
            ['|', ('requested_by', '=', user.id), ('department_id.manager_id.user_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('ti_workflow_core.group_production_supervisor'))]"/>
    </record>

</odoo>
