<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         TI WORKFLOW CORE — RECORD RULES
         Multi-company isolation for the audit log and timeline. Both
         models record a company_id at write time; users only see entries
         for companies they have access to (or entries with no company set,
         e.g. cross-company configuration actions).
    ============================================================ -->

    <record id="rule_workflow_log_company" model="ir.rule">
        <field name="name">TI Workflow Log: multi-company</field>
        <field name="model_id" ref="model_ti_workflow_log"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

    <record id="rule_document_timeline_company" model="ir.rule">
        <field name="name">TI Document Timeline: multi-company</field>
        <field name="model_id" ref="model_ti_document_timeline"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

</odoo>
