<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_mr_issue_partial_wizard" model="ir.actions.act_window">
        <field name="name">Issue Materials (Partial)</field>
        <field name="res_model">ti.issue.materials.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ti_issue_materials_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_mr_id': active_id}</field>
    </record>

    <record id="action_mr_return_wizard" model="ir.actions.act_window">
        <field name="name">Process Return</field>
        <field name="res_model">ti.stock.return.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ti_stock_return_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'default_mr_id': active_id}</field>
    </record>

</odoo>
